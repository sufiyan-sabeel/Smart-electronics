<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 600" width="600" height="600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0077B6"/>
      <stop offset="100%" style="stop-color:#0096D6"/>
    </linearGradient>
    <linearGradient id="shine" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(255,255,255,0.15)"/>
      <stop offset="100%" style="stop-color:rgba(255,255,255,0)"/>
    </linearGradient>
  </defs>
  <rect width="600" height="600" fill="url(#bg)" rx="24"/>
  <rect width="600" height="300" fill="url(#shine)" rx="24"/>
  <text x="300" y="270" font-family="system-ui, -apple-system, sans-serif" font-size="80" text-anchor="middle" dominant-baseline="central">💻</text>
  <rect x="60" y="380" width="480" height="3" rx="1.5" fill="rgba(255,255,255,0.2)"/>
  <text x="300" y="420" font-family="system-ui, -apple-system, sans-serif" font-size="24" font-weight="700" fill="white" text-anchor="middle">Dell XPS 14 - Side</text>
  <text x="300" y="455" font-family="system-ui, -apple-system, sans-serif" font-size="16" fill="rgba(255,255,255,0.6)" text-anchor="middle">Dell</text>
</svg>