<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 600" width="600" height="600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0084C8"/>
      <stop offset="100%" style="stop-color:#00A3E0"/>
    </linearGradient>
    <linearGradient id="shine" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(255,255,255,0.15)"/>
      <stop offset="100%" style="stop-color:rgba(255,255,255,0)"/>
    </linearGradient>
  </defs>
  <rect width="600" height="600" fill="url(#bg)" rx="20"/>
  <rect width="600" height="300" fill="url(#shine)" rx="20"/>
  <text x="300" y="280" font-family="system-ui, -apple-system, sans-serif" font-size="100" text-anchor="middle" dominant-baseline="central">💻</text>
  <rect x="50" y="400" width="500" height="4" rx="2" fill="rgba(255,255,255,0.2)"/>
  <text x="300" y="440" font-family="system-ui, -apple-system, sans-serif" font-size="28" font-weight="700" fill="white" text-anchor="middle">Dell XPS 14</text>
  <text x="300" y="480" font-family="system-ui, -apple-system, sans-serif" font-size="18" fill="rgba(255,255,255,0.6)" text-anchor="middle">Dell</text>
</svg>